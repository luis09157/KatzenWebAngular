{
  "database": {
    "rules": "database.rules.json"
  },
  "functions": {
    "source": "functions",
    "codebase": "default"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "dist/katzenvet",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
